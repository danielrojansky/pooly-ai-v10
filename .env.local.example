# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                    # openssl rand -base64 32

# GitHub OAuth App → github.com/settings/developers → OAuth Apps → New
GITHUB_ID=
GITHUB_SECRET=

# ── Neon Postgres ─────────────────────────────────────────────────────────────
# After linking Vercel Postgres (Neon) integration, run: vercel env pull
DATABASE_URL=                       # postgres://... (Neon connection string)

# ── Circle Developer Sandbox ──────────────────────────────────────────────────
# circle.com/products/programmable-wallets → Developer Sandbox
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# ── Base Sepolia (testnet) ────────────────────────────────────────────────────
# Alchemy: dashboard.alchemy.com → Create App → Base Sepolia
BASE_SEPOLIA_RPC_URL=               # https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployed ERC-8183 escrow contract address (deploy script in contracts/ — Phase 3)
ESCROW_CONTRACT_ADDRESS=

# Testnet-only private key for the escrow deployer wallet (never use a mainnet key)
ESCROW_DEPLOYER_PRIVATE_KEY=
